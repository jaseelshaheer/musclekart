<section class="account-page">
  <div class="account-layout">

    <!-- SIDEBAR -->
    <%- include("../profile/_sidebar") %>

    <!-- CONTENT -->
    <main class="content">
      <div class="profile-box">

        <div class="profile-header">
          <h2><%= address ? "Edit Address" : "Add New Address" %></h2>
        </div>

        <form
            id="addressForm"
            data-edit="<%= address ? 'true' : 'false' %>"
            data-address-id="<%= address?._id || '' %>"
        >

          <div class="form-group">
            <label>Name</label>
            <input
              id="name"
              type="text"
              name="name"
              value="<%= address?.name || '' %>"
            />
          </div>

          <div class="form-group">
            <label>Phone</label>
            <input
              id="phone"
              type="tel"
              name="phone"
              value="<%= address?.phone || '' %>"
            />
          </div>

          <div class="form-group">
            <label>House / Building</label>
            <input
              id="house"
              type="text"
              name="house"
              value="<%= address?.house || '' %>"
            />
          </div>

          <div class="form-group">
            <label>Country</label>
            <input
              id="country"
              type="text"
              name="country"
              value="<%= address?.country || '' %>"
            />
          </div>


          <div class="form-group">
            <label>District / City</label>
            <input
              id="district"
              type="text"
              name="district"
              value="<%= address?.district || '' %>"
            />
          </div>

          <div class="form-group">
            <label>State</label>
            <input
              id="state"
              type="text"
              name="state"
              value="<%= address?.state || '' %>"
            />
          </div>

          <div class="form-group">
            <label>Pincode</label>
            <input
              id="pincode"
              type="text"
              name="pincode"
              value="<%= address?.pincode || '' %>"
            />
          </div>

          <div class="form-group">
            <label>Landmark (optional)</label>
            <input
              id="landmark"
              type="text"
              name="landmark"
              value="<%= address?.landmark || '' %>"
            />
          </div>

          <div class="form-group">
            <label>Address Type</label>
            <select id="addressType" name="addressType">
              <option id="home" value="home" <%= address?.addressType === "home" ? "selected" : "" %>>Home</option>
              <option id="work" value="work" <%= address?.addressType === "work" ? "selected" : "" %>>Work</option>
            </select>
          </div>

          <div class="form-group checkbox-group">
            <label class="checkbox-label">
                <input
                id="isDefault"
                type="checkbox"
                name="isDefault"
                <%= address?.isDefault ? "checked" : "" %>
                />
                <span>Make this default address</span>
            </label>
          </div>



          <div class="form-actions">
            <button type="submit" class="primary-btn">
              <%= address ? "Update Address" : "Save Address" %>
            </button>
            <a href="/addresses" class="secondary-btn">Cancel</a>
          </div>

        </form>

      </div>
    </main>

  </div>
</section>


<script src="/js/address-form.js"></script>
