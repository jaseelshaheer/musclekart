<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>MuscleKart</title>
  <link rel="icon" href="/images/favicon.png" type="image/png" />

  <link rel="stylesheet" href="/css/variables.css">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/user.css">
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css"
  />
</head>
<body>
  
  <main>
    <%- body %>
  </main>

  <div id="confirmModal" class="confirm-modal hidden">

    <div class="confirm-box">

      <p id="confirmMessage">
        Are you sure you want to delete this item?
      </p>

      <div class="confirm-actions">

        <button id="confirmCancel" class="secondary-btn">
          Cancel
        </button>

        <button id="confirmOk" class="danger-btn">
          Confirm
        </button>

      </div>

    </div>

  </div>

  <div id="globalAlertModal" class="modal hidden">
    <div class="modal-card">
      <div class="modal-header">
        <h3 id="alertTitle">Notice</h3>
      </div>

      <div class="modal-body">
        <p id="alertMessage" style="font-size:14px; color:#555;"></p>
      </div>

      <div class="modal-footer">
        <button id="alertOkBtn" class="btn-submt">OK</button>
      </div>
    </div>
  </div>

  <div id="globalToast" class="toast hidden">
    <span id="toastMessage"></span>
  </div>



  <script src="/js/header.js"></script>
  <script src="/js/auth-ui.js"></script>
  <script src="/js/confirm.js"></script>
  <script src="/js/signup.js"></script>
  <script src="/js/otp.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
</body>
</html>