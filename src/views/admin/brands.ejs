<div class="admin-layout">

  <%- include("../partials/admin-sidebar") %>

  <main class="admin-main">

    <!-- PAGE HEADER -->
    <div class="admin-page-header">

      <div>
        <h1>Brands</h1>
        <p class="breadcrumb">Dashboard / Brands</p>
      </div>

      <div class="search-wrapper">
        <input
          type="text"
          id="searchInput"
          placeholder="Search brand..."
        />
        <button id="clearSearch">✕</button>
      </div>

    </div>


    <!-- TABLE CARD -->

    <div class="admin-card">

      <div style="margin-bottom:16px;">
        <button id="addBrandBtn" class="btn-primary">
          + Add Brand
        </button>
      </div>


      <table class="admin-table">

        <thead>
          <tr>
            <th>SNO</th>
            <th>Brand</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>

        <tbody id="brandTable">
          <!-- JS will inject rows -->
        </tbody>

      </table>


      <!-- PAGINATION -->

      <div class="admin-pagination">
        <button id="prevBtn">Previous</button>
        <span id="pageInfo"></span>
        <button id="nextBtn">Next</button>
      </div>

    </div>

  </main>

</div>



<!-- BRAND MODAL -->

<div id="brandModal" class="modal hidden">

  <div class="modal-card">

    <h3 id="modalTitle">Add Brand</h3>

    <form id="brandForm">

      <input type="hidden" id="brandId">

      <div class="modal-body">

        <input
          type="text"
          id="brandName"
          class="modal-input"
          placeholder="Brand Name"
          maxlength="50"
        >
        <small class="field-error" id="brandNameError"></small>
        <small class="char-count" id="brandNameCount">0 / 50</small>


      </div>

      <div class="modal-actions">

        <button type="button" id="closeModalBtn" class="btn-cncel">
          Cancel
        </button>

        <button type="submit" class="btn-submt">
          Save
        </button>

      </div>

    </form>

  </div>

</div>


<script src="/js/confirm.js"></script>
<script src="/js/brand-management.js"></script>